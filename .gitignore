# Python virtual environment. Never commit; it's machine-specific and large
.venv/

# Python bytecode caches
__pycache__/
*.py[cod]

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Raw/large data - regenerate from source instead of committing
data/raw/*.csv
data/raw/*.parquet
data/*.parquet

# Serving artifacts downloaded from the GitHub Release at runtime (the committed
# snapshot under data/serving/ is the offline fallback).
data/_serving_cache/

# DuckDB database file - regenerable from the raw CSVs via src/load_duckdb.py
data/*.duckdb
data/*.duckdb.wal

# Pickle models are never committed (code-execution risk). The native-JSON model
# under models/ IS committed as a serving artifact - safe to share, version-stable.
models/*.pkl

# Runtime logs
*.log

# dbt build artifacts - regenerated on every run
transform/target/
transform/logs/
transform/.user.yml

# OS / editor cruft
.DS_Store
.vscode/

# Personal learning notes - kept local, not part of the public portfolio
docs/ml-lesson.md

# Automated refresh job log
refresh.log
