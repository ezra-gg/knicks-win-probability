# Python virtual environment. Never commit; it's machine-specific and large
.venv/

# Python bytecode caches
__pycache__/
*.py[cod]

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Raw/large data - regenerate from source instead of committing
data/raw/*.csv
data/raw/*.parquet
data/*.parquet

# DuckDB database file - regenerable from the raw CSVs via src/load_duckdb.py
data/*.duckdb
data/*.duckdb.wal

# Trained model artifacts (optional; see README, we may commit a small final model)
models/*.pkl

# OS / editor cruft
.DS_Store
.vscode/

# Personal learning notes - kept local, not part of the public portfolio
docs/ml-lesson.md
